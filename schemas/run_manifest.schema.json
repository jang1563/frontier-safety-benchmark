{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/cbrn-ai-2.0/run_manifest.schema.json",
  "title": "CBRN-AI 2.0 Run Manifest",
  "description": "Machine-readable metadata for a benchmark run or report-generation step.",
  "type": "object",
  "required": [
    "manifest_version",
    "run_id",
    "benchmark_version",
    "run_type",
    "script_path",
    "command",
    "input_files",
    "output_files",
    "generated_by",
    "notes"
  ],
  "additionalProperties": false,
  "properties": {
    "manifest_version": {
      "type": "string",
      "pattern": "^run-manifest-v[0-9]+$"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "benchmark_version": {
      "type": "string",
      "minLength": 1
    },
    "run_type": {
      "type": "string",
      "enum": [
        "coverage_report",
        "public_response_audit",
        "release_metadata",
        "validation"
      ]
    },
    "script_path": {
      "type": "string",
      "minLength": 1
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "input_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "output_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "generated_by": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  }
}
